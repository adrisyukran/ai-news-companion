# AI News Companion - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: NanoGPT API Configuration
# =============================================================================

# Your nano-gpt API key - obtain from https://nano-gpt.com/
NANO_GPT_API_KEY=your_nano_gpt_api_key_here

# =============================================================================
# OPTIONAL: Application Settings
# =============================================================================

# Set to "true" to enable debug logging (default: false)
DEBUG=false

# =============================================================================
# NOTES:
# =============================================================================
# - The API key is required for all LLM operations (summarization, translation, chat)
# - Never commit your actual .env file to version control
# - Restart the server after modifying .env for changes to take effect